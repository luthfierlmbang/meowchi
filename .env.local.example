# Mochi Virtual Pet — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# Frontend-safe Supabase values (okay to expose)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only Gemini API key. Set this in Vercel as GEMINI_API_KEY.
# Do not prefix with VITE_.
GEMINI_API_KEY=

# Legacy only: Habit Vision still reads this until /api/vision is migrated.
VITE_GEMINI_API_KEY=
